<assembly
	xmlns="http://maven.apache.org/plugins/maven-assembly-plugin/assembly/1.1.2"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://maven.apache.org/plugins/maven-assembly-plugin/assembly/1.1.2 http://maven.apache.org/xsd/assembly-1.1.2.xsd">
	<id>dir</id>
	<includeBaseDirectory>false</includeBaseDirectory>
	<formats>
		<format>
			zip
		</format>
	</formats>
	<fileSets>
		<fileSet>
			<directory>${project.basedir}/synclite-consolidator/root/web/target
			</directory>
			<includes>
				<include>*.war</include>
			</includes>
			<fileMode>755</fileMode>
			<directoryMode>755</directoryMode>
			<outputDirectory>tools/synclite-consolidator</outputDirectory>
		</fileSet>
		<fileSet>
			<directory>${project.basedir}/synclite-sample-web-app/web/target
			</directory>
			<includes>
				<include>*.war</include>
			</includes>
			<fileMode>755</fileMode>
			<directoryMode>755</directoryMode>
			<outputDirectory>tools/synclite-sample-app</outputDirectory>
		</fileSet>
		<fileSet>
			<directory>${project.basedir}/synclite-logger-java/logger/target
			</directory>
			<includes>
				<include>*.jar</include>
			</includes>
			<fileMode>755</fileMode>
			<directoryMode>755</directoryMode>
			<outputDirectory>lib/java</outputDirectory>
		</fileSet>
		<fileSet>
			<directory>${project.basedir}/synclite-logger-java/logger/src/main/resources
			</directory>
			<includes>
				<include>*.conf</include>
			</includes>
			<outputDirectory>lib/java</outputDirectory>
		</fileSet>
		<fileSet>
			<!-- C/C++ SDK only: the C-ABI cdylib (synclite_1_0_0.dll on Windows,
			     libsynclite_1_0_0.so/.dylib on Linux/macOS) + its Windows import/static
			     libs + cross-compiled Linux .so variants. The Java JNI native (synclite_jni)
			     is shipped inside the logger jar under lib/java
			     (META-INF/native/<classifier>/libsynclite_<rev>_jni.<ext>) and the
			     Python _native ext ships inside the wheel under lib/python, so neither
			     is duplicated loose here. -->
			<directory>${project.basedir}/synclite-logger-rust/target/release</directory>
			<includes>
				<include>${rust.logger.include.dll}</include>
				<include>${rust.logger.include.lib}</include>
				<include>${rust.logger.include.so}</include>
				<include>${rust.logger.include.dylib}</include>
			</includes>
			<fileMode>755</fileMode>
			<directoryMode>755</directoryMode>
			<outputDirectory>lib/native</outputDirectory>
		</fileSet>
		<fileSet>
			<!-- C/C++ ABI headers consumed by sample-apps/cpp. -->
			<directory>${project.basedir}/synclite-logger-rust/include</directory>
			<includes>
				<include>synclite.h</include>
				<include>synclite.hpp</include>
			</includes>
			<fileMode>644</fileMode>
			<outputDirectory>lib/native/include</outputDirectory>
		</fileSet>
		<fileSet>
			<directory>${project.build.directory}</directory>
			<includes>
				<include>synclite.conf</include>
			</includes>
			<fileMode>644</fileMode>
			<outputDirectory>lib/native</outputDirectory>
		</fileSet>
		<fileSet>
			<!--
			  Self-contained Rust SDK source tree staged by pom.xml's
			  `stage-rust-source-tree` antrun step. Cargo workspace with all
			  SyncLite crates needed by the Rust sample (synclite facade +
			  logger + consolidator + observability), minus the language-binding
			  crates. The release Rust sample uses path dependencies into this
			  tree so `cargo run` works offline.
			-->
			<directory>${project.basedir}/synclite-logger-rust/target/lib-rust-release/synclite-source</directory>
			<fileMode>644</fileMode>
			<directoryMode>755</directoryMode>
			<outputDirectory>lib/rust/synclite-source</outputDirectory>
		</fileSet>
		<fileSet>
			<!--
			  Host + cross-built PyO3 wheels produced by maturin (see pom.xml
			  build-python-wheel and build-python-wheel-linux-*). Ships the same
			  self-contained wheels as the exploded platform folder
			  (assembly/platform.xml) and the runtime zip (assembly/runtime_zip.xml)
			  so end users `pip install lib/python/synclite-*.whl` without a Rust
			  toolchain. The glob matches every platform-tagged wheel (Windows +
			  Linux x86_64/aarch64 + any macOS wheels present).
			-->
			<directory>${project.basedir}/synclite-logger-rust/python/dist</directory>
			<includes>
				<include>synclite-${revision}-*.whl</include>
			</includes>
			<fileMode>644</fileMode>
			<directoryMode>755</directoryMode>
			<outputDirectory>lib/python</outputDirectory>
		</fileSet>
		<fileSet>
			<directory>${project.basedir}/synclite-code-samples</directory>
			<outputDirectory>/sample-apps/</outputDirectory>
			<excludes>
				<!-- Local developer artifacts that must not ship with the platform zip. -->
				<exclude>**/target/**</exclude>
				<exclude>**/Cargo.lock</exclude>
				<exclude>**/*.log</exclude>
				<exclude>**/*_out.txt</exclude>
				<exclude>**/run.log</exclude>
				<exclude>**/run_out.txt</exclude>
				<exclude>**/*.synclite/**</exclude>
				<exclude>**/*.db</exclude>
				<exclude>**/*.duckdb</exclude>
				<exclude>**/*.sqlite</exclude>
			</excludes>
		</fileSet>
		<fileSet>
			<directory>${project.basedir}/synclite-client/client/target
			</directory>
			<includes>
				<include>*.jar</include>
				<include>synclite-client.*</include>
				<include>*.conf</include>
			</includes>
			<fileMode>755</fileMode>
			<directoryMode>755</directoryMode>			
			<outputDirectory>tools/synclite-client</outputDirectory>
		</fileSet>
		<fileSet>
			<directory>${project.basedir}/synclite-db/root/web/target
			</directory>
			<includes>
				<include>*.war</include>
			</includes>
			<fileMode>755</fileMode>
			<directoryMode>755</directoryMode>
			<outputDirectory>tools/synclite-db</outputDirectory>
		</fileSet>
		<fileSet>
			<!-- SyncLite DB client SDK sources (per-language quickstarts). -->
			<directory>${project.basedir}/synclite-db/sdk-source</directory>
			<fileMode>644</fileMode>
			<directoryMode>755</directoryMode>
			<outputDirectory>tools/synclite-db/sdk-source</outputDirectory>
			<excludes>
				<exclude>**/target/**</exclude>
				<exclude>**/Cargo.lock</exclude>
				<exclude>**/*.log</exclude>
				<exclude>**/*.class</exclude>
			</excludes>
		</fileSet>
		<fileSet>
			<directory>${project.basedir}/synclite-dbreader/root/web/target
			</directory>
			<includes>
				<include>*.war</include>
			</includes>
			<fileMode>755</fileMode>
			<directoryMode>755</directoryMode>			
			<outputDirectory>tools/synclite-dbreader</outputDirectory>
		</fileSet>
		<fileSet>
			<directory>${project.basedir}/synclite-qreader/root/web/target
			</directory>
			<includes>
				<include>*.war</include>
			</includes>
			<fileMode>755</fileMode>
			<directoryMode>755</directoryMode>			
			<outputDirectory>tools/synclite-qreader</outputDirectory>
		</fileSet>
		<fileSet>
			<directory>${project.basedir}/synclite-job-monitor/root/web/target
			</directory>
			<includes>
				<include>*.war</include>
			</includes>
			<fileMode>755</fileMode>
			<directoryMode>755</directoryMode>		
			<outputDirectory>tools/synclite-jobmonitor</outputDirectory>
		</fileSet>
		<fileSet>
			<directory>${project.basedir}</directory>
			<includes>
				<include>LICENSE</include>
			</includes>	
			<outputDirectory>licenses</outputDirectory>
		</fileSet>
		<fileSet>
			<directory>${project.basedir}/synclite-consolidator/root/core/target/generated-resources</directory>
			<outputDirectory>licenses/third-party-software</outputDirectory>
		</fileSet>
		<fileSet>
			<directory>${project.basedir}/bin</directory>
			<includes>
				<include>**/*</include>
			</includes>
			<excludes>
				<!-- Runtime artifacts from local Tomcat runs - bin/deploy.* copies WARs from
				     tools/synclite-*/ into webapps/ at first start; Tomcat re-explodes on boot. -->
				<exclude>apache-tomcat-*/webapps/synclite-*/**</exclude>
				<exclude>apache-tomcat-*/webapps/synclite-*.war</exclude>
				<exclude>apache-tomcat-*/work/**</exclude>
				<exclude>apache-tomcat-*/temp/**</exclude>
				<exclude>apache-tomcat-*/logs/**</exclude>
				<exclude>**/*.trace</exclude>
				<exclude>**/*.log</exclude>
				<exclude>derby.log</exclude>
			</excludes>
			<fileMode>755</fileMode>
			<directoryMode>755</directoryMode>
			<outputDirectory>/bin</outputDirectory>
		</fileSet>
		<fileSet>
			<directory>${project.basedir}</directory>
			<includes>
				<include>README.md</include>
				<include>LICENSE</include>
				<include>synclite_platform_version.txt</include>
			</includes>
			<fileMode>644</fileMode>
			<outputDirectory>/</outputDirectory>
		</fileSet>
	</fileSets>
</assembly>
